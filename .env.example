# DashScope / 百炼 Key
# 推荐设置这个变量，因为 ChatTongyi 和 DashScopeEmbeddings 默认读取 DASHSCOPE_API_KEY
DASHSCOPE_API_KEY=你的百炼key

# 如果你之前只设置了 OPENAI_API_KEY，本项目的 model/factory.py 也做了兼容：
# 会在没有 DASHSCOPE_API_KEY 时尝试读取 OPENAI_API_KEY
OPENAI_API_KEY=你的百炼key

# 数据库连接（必填）
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/remote_rag?charset=utf8mb4

# 是否打印 SQL 日志（true/false，默认 false）
SQL_ECHO=false

# CORS 允许的前端来源（逗号分隔，默认 http://localhost:8501）
CORS_ORIGINS=http://localhost:8501

# 前端 API 地址
API_BASE_URL=http://localhost:8000
